{
  "name": "doomsday-gates",
  "version": "1.0.0",
  "description": "A Last War style left/right gate-choosing runner built with three.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:pages": "vite build --base=/Doomsday-Gates/",
    "preview": "vite preview",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "mobile:android:init": "tauri android init --ci",
    "mobile:android:build:debug": "tauri android build --debug --apk -t aarch64 --ci",
    "mobile:android:build": "tauri android build --apk --aab -t aarch64 --ci",
    "mobile:ios:init": "tauri ios init --ci",
    "mobile:ios:build:sim": "tauri ios build --debug --target aarch64-sim --no-sign --ci",
    "mobile:ios:build": "tauri ios build --export-method app-store-connect --ci"
  },
  "dependencies": {
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "vite": "^8.1.3"
  }
}
